# Douyin/YouTube 설정
YT_CLIENT_SECRET_PATH=./google_credentials/client_secret.json
YT_OAUTH_TOKEN_FILE=./google_credentials/oauth2_token.json
YT_CATEGORY_ID=24  # 24: Entertainment, 22: People&Blogs 등 Shorts 적합 카테고리

# FFmpeg 설정
FFMPEG_PATH=ffmpeg  # 시스템 PATH에 등록 시 그대로 사용
AUDIO_ISOLATION_MODE=native  # native | demucs (Demucs 사용 시 torch 필요)

# TTS/자막 설정
TTS_VOICE=ko-KR-InHeeNeural  # ko-KR-SunHiNeural, ko-KR-JiMinNeural 등
SUBTITLE_FONT_SIZE=24
SUBTITLE_STYLE=PrimaryColour=&HFFFFFF&H000000FF&H000000FF&HFFFFFF00